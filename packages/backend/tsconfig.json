{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "target": "esnext",
    "sourceRoot": "./src",
    "rootDir": "./src",
    "baseUrl": "./",
    "outDir": "build",
    "paths": {
      "infrastructure/*": ["./src/infrastructure/*"],
      "application/*": ["./src/application/*"],
      "domain/*": ["./src/domain/*"]
    }
  },
  "include": ["src/"]
}
